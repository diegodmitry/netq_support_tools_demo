NETQ_ENVIRONMENT=dev
NETQ_API_PREFIX=/api/v1

NETQ_SESSION_COOKIE_NAME=netq_session
NETQ_SESSION_IDLE_TIMEOUT_SECONDS=28800
NETQ_KEEP_ALIVE_INTERVAL_SECONDS=300
NETQ_OUTBOUND_HTTP_TIMEOUT_SECONDS=5.0
NETQ_OUTBOUND_HTTP_MAX_RETRIES=2
NETQ_OUTBOUND_HTTP_RETRY_BACKOFF_SECONDS=0.2
NETQ_AUTH_PROVIDER=mock

NETQ_ALLOWED_USERS=jdoe,operator
# NETQ_ALLOWED_USERS_FILE=/run/secrets/netq_allowed_users
# Optional bridge for local real-environment testing from the legacy app config:
# NETQ_LEGACY_CONFIG_FILE=../NetQTools/conf/app_DEV.json

NETQ_MOCK_PASSWORD=secret
# NETQ_MOCK_PASSWORD_FILE=/run/secrets/netq_mock_password

# Prefer `NETQ_LEGACY_CONFIG_FILE` for local migration testing with legacy values.
# If you set LDAP values explicitly here, they override the legacy bridge.
# NETQ_LDAP_SERVER=ldap.example.internal
# NETQ_LDAP_PORT=3269
# NETQ_LDAP_USER_DN=CN=real-service-account,...
# NETQ_LDAP_USER_DB_PASSWORD_FILE=/run/secrets/netq_ldap_bind_password

NETQ_MONGO_PROD_URL=https://mongo-prod.example/netq/test/
NETQ_MONGO_PROD_BASIC_AUTH_ENABLED=true
NETQ_MONGO_PROD_BASIC_AUTH_USER=netq
# NETQ_MONGO_PROD_BASIC_AUTH_PASS_FILE=/run/secrets/netq_mongo_prod_password

NETQ_AUDIT_PROD_URL=https://audit-prod.example/netq/audit/
NETQ_AUDIT_PROD_BASIC_AUTH_ENABLED=false
NETQ_AUDIT_PROD_BASIC_AUTH_USER=
# NETQ_AUDIT_PROD_BASIC_AUTH_PASS_FILE=/run/secrets/netq_audit_prod_password

NETQ_MONGO_QA_URL=https://mongo-qa.example/netq/test/
NETQ_AUDIT_QA_URL=https://audit-qa.example/netq/audit/
NETQ_AUX_URL=?related=true
NETQ_AUX_URL_AUDIT=?cache=true
NETQ_SAPA_URL=https://sapa.example/query?id_servico=

NETQ_SIGRA_APP=NETQ
NETQ_SIGRA_CODE_APP=99
NETQ_SIGRA_URL=https://sigra.example/service
NETQ_SIGRA_ACTION=https://sigra.example/action
NETQ_SIGRA_TIMEOUT_SECONDS=30
